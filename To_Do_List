from tkinter import *
from tkinter import messagebox
def add_task():
    task = task_entry.get()
    if task != "":
        task_listbox.insert(END, task)
        task_entry.delete(0, END)
    else:
        messagebox.showwarning("Warning", "Please enter a task!")
def delete_task():
    try:
        selected = task_listbox.curselection()
        task_listbox.delete(selected)
    except:
        messagebox.showwarning("Warning", "Select a task to delete!")
def clear_tasks():
    answer = messagebox.askyesno("Confirm","Do you want to clear all tasks?")
    if answer:
        task_listbox.delete(0, END)
root = Tk()
root.title("To-Do List Application")
root.geometry("400x500")
root.resizable(False, False)
title = Label(root,text="TO-DO LIST",font=("Arial", 18, "bold"))
title.pack(pady=10)
task_entry = Entry(root,font=("Arial", 14),width=25)
task_entry.pack(pady=10)
add_btn = Button(root,text="Add Task",width=15,command=add_task)
add_btn.pack(pady=5)
task_listbox = Listbox(root,width=40,height=15,font=("Arial", 12))
task_listbox.pack(pady=10)
delete_btn = Button(root,text="Delete Selected",width=15,command=delete_task)
delete_btn.pack(pady=5)
clear_btn = Button(root,text="Clear All",width=15,command=clear_tasks)
clear_btn.pack(pady=5)
root.mainloop()